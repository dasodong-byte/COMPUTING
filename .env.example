# Database (PostgreSQL) — used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/computing_services?schema=public"

# Public site URL (used for SEO metadata, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL="https://www.computing-services.fr"

# Auth — secret used to sign JWT session cookies (min 16 chars, use a long random value in production)
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Optional: password assigned to the demo accounts created by `npm run db:seed`
# SEED_PASSWORD="Password123!"
